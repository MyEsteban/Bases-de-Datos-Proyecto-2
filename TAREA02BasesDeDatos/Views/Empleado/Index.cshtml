@model IEnumerable<TAREA02BasesDeDatos.Models.Empleado>

@{
    ViewData["Title"] = "Gestión de Empleados";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people-fill"></i> Lista de Empleados</h2>
        <div>
            <span class="badge bg-secondary p-2">
                Usuario: @Context.Session.GetString("NombreUsuario")
            </span>
            <a asp-controller="Login" asp-action="Logout" class="btn btn-outline-danger btn-sm ms-2">Salir</a>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Nombre</label>
                    <input type="text" name="nombre" class="form-control" value="@ViewBag.FiltroNombre" placeholder="Ej: Juan..." />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Cédula</label>
                    <input type="text" name="cedula" class="form-control" value="@ViewBag.FiltroCedula" placeholder="Ej: 11234..." />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">Buscar</button>
                    <a asp-action="Index" class="btn btn-light border">Limpiar</a>
                </div>
            </form>
        </div>
    </div>

    <div class="mb-3">
        <a asp-action="Crear" class="btn btn-success"><i class="bi bi-plus-circle"></i> Nuevo Empleado</a>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-warning">@ViewBag.Error</div>
    }

    <div class="table-responsive shadow rounded">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Cédula</th>
                    <th>Puesto</th>
                    <th>Saldo Vacaciones</th>
                    <th>Contratación</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Nombre</strong></td>
                        <td>@item.ValorDocumentoIdentidad</td>
                        
                        <td class="text-primary fw-bold">@item.SaldoVacaciones.ToString("N2")</td>
                        <td>@item.FechaContratacion.ToShortDateString()</td>
                        <td>
                            <span class="badge @(item.EsActivo ? "bg-success" : "bg-danger")">
                                @(item.EsActivo ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-warning">Editar</a>
                                <a asp-action="Movimientos" asp-route-id="@item.Id" class="btn btn-info text-white" title="Ver Movimientos">
                                    <i class="bi bi-eye"></i> Movs
                                </a>
                                <form asp-action="Eliminar" asp-route-id="@item.Id" method="post" style="display:inline;"
                                      onsubmit="return confirm('Valor de identidad: @item.ValorDocumentoIdentidad \nNombre: @item.Nombre \n\n¿Está seguro de eliminar este empleado?');">
                                    <button type="submit" class="btn btn-danger" title="Borrar">Eliminar</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">No se encontraron empleados con esos filtros.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>