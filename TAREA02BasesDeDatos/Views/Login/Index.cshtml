@model TAREA02BasesDeDatos.Models.LoginViewModel

@{
    Layout = null; // Esto es para que no aparezca la barra de navegación antes de loguearse
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ingreso - Sistema de Vacaciones</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
            body {
                background-color: #f8f9fa;
            }
            .login-container {
                margin-top: 10%;
            }
            .card {
                border-radius: 15px;
                border: none;
            }
            .card-header {
                border-radius: 15px 15px 0 0 !important;
            }
    </style>
</head>
<body>

    <div class="container login-container">
        <div class="row justify-content-center">
            <div class="col-md-4">
                <div class="card shadow-lg">
                    <div class="card-header bg-dark text-white text-center py-3">
                        <h4 class="mb-0">Control de Vacaciones</h4>
                    </div>
                    <div class="card-body p-4">
                        
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger" role="alert">
                                @ViewBag.Error
                            </div>
                        }

                        <form asp-action="Index" asp-controller="Login" method="post">
                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                <label asp-for="Username" class="form-label">Usuario</label>
                                <input asp-for="Username" class="form-control" placeholder="Ingrese su usuario" required autofocus />
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label">Contraseña</label>
                                <input asp-for="Password" type="password" class="form-control" placeholder="********" required />
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary btn-lg">Entrar</button>
                            </div>
                        </form>
                    </div>
                    <div class="card-footer text-center text-muted small">
                        © 2026 - Tarea #2 Bases de Datos
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>